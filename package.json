{
  "name": "quorum",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Incident command plane on Aurora DSQL (multi-region) — H0 hackathon",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
