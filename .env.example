# Copy to .env and fill in. NEVER commit a populated .env. Values are examples of NAMES
# only, no real values belong in this file.

# --- AWS ---
AWS_PROFILE=
AWS_REGION=

# --- Aurora DSQL (active-active pair; the app data layer fails over across these) ---
# Primary cluster endpoint + region. Single-endpoint tools (migrate, seed, ingest) use these.
DSQL_ENDPOINT_PRIMARY=
DSQL_REGION=
# Secondary region for the app failover layer (omit for a single-region setup).
DSQL_ENDPOINT_SECONDARY=
DSQL_REGION_SECONDARY=
# Optional overrides (defaults: database=postgres, user=admin).
DSQL_DATABASE=
DSQL_USER=

# --- Migration runner ---
MIGRATIONS_DIR=

# --- Alerts (infra/bootstrap) ---
ALERT_EMAIL=

# --- Vercel (deploy preflight, see CLAUDE.md "Vercel deployment policy", DEC-009) ---
# Expected Vercel account/username for THIS project. scripts/preflight-vercel.sh compares
# `vercel whoami` against it and refuses to deploy on mismatch. Real value goes in the
# gitignored .env.local, never here.
VERCEL_EXPECTED_ACCOUNT=

# --- Lambda runtime envs (set by Terraform, not for local dev) ---
# infra/monitor sets MONITOR_EVENTS (probe writes per run); infra/ingest and infra/monitor set
# DSQL_ENDPOINT_PRIMARY / DSQL_REGION on the function. Listed here only for reference.
